{
  "info": {
    "_postman_id": "84826b52-cb45-4299-8c67-a2f2efcf72da",
    "name": "RNT MPL Authentication API",
    "description": "Postman collection for RNT MPL Multi-tenant Cricket Platform authentication and onboarding endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication & OTP",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"full_name\": \"John Doe\",\n  \"password\": \"SecurePass123!\",\n  \"password_confirm\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "register",
                ""
              ]
            },
            "description": "Registers a new user and returns JWT tokens along with user profile data."
          },
          "response": []
        },
        {
          "name": "Login (Password)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.tokens) {",
                  "    pm.environment.set(\"access_token\", jsonData.tokens.access);",
                  "    pm.environment.set(\"refresh_token\", jsonData.tokens.refresh);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login",
                ""
              ]
            },
            "description": "Authenticates user with email and password, returning JWT access and refresh tokens."
          },
          "response": []
        },
        {
          "name": "Request OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email_or_phone\": \"user@example.com\",\n  \"purpose\": \"LOGIN\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/otp/request/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "otp",
                "request",
                ""
              ]
            },
            "description": "Requests a 6-digit OTP code to be sent via email (or SMS for phones) for registration, login, or verification."
          },
          "response": []
        },
        {
          "name": "Verify OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.tokens) {",
                  "    pm.environment.set(\"access_token\", jsonData.tokens.access);",
                  "    pm.environment.set(\"refresh_token\", jsonData.tokens.refresh);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email_or_phone\": \"user@example.com\",\n  \"otp\": \"123456\",\n  \"purpose\": \"LOGIN\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/otp/verify/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "otp",
                "verify",
                ""
              ]
            },
            "description": "Verifies the 6-digit OTP and authenticates the user, returning JWT access and refresh tokens."
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.access) {",
                  "    pm.environment.set(\"access_token\", jsonData.access);",
                  "}",
                  "if (jsonData.refresh) {",
                  "    pm.environment.set(\"refresh_token\", jsonData.refresh);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/refresh/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "refresh",
                ""
              ]
            },
            "description": "Submits a refresh token to receive a fresh access token."
          },
          "response": []
        },
        {
          "name": "Verify Email Link",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"some_verification_token\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/verify-email/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "verify-email",
                ""
              ]
            },
            "description": "Verify user's email using a link token."
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/logout/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "logout",
                ""
              ]
            },
            "description": "Logs out the authenticated user and blacklists their refresh token."
          },
          "response": []
        }
      ]
    },
    {
      "name": "User & Organization",
      "item": [
        {
          "name": "Current User (Me)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/me/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "me",
                ""
              ]
            },
            "description": "Retrieves profiles, roles, and tenant memberships of the currently authenticated user."
          },
          "response": []
        },
        {
          "name": "Onboard Tenant",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mumbai Cricket Academy\",\n  \"tenant_type\": \"ACADEMY\",\n  \"subdomain\": \"mca\",\n  \"primary_color\": \"#1a56db\",\n  \"secondary_color\": \"#7c3aed\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/onboard-tenant/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "onboard-tenant",
                ""
              ]
            },
            "description": "Onboards a new tenant organization (e.g. Academy, Club, League) under the logged-in user."
          },
          "response": []
        }
      ]
    }
  ],
